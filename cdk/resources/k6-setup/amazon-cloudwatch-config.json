{
    "agent": {
            "metrics_collection_interval": 60,
            "run_as_user": "root"
    },
    "metrics": {
            "namespace": "K6",
            "append_dimensions": {
                    "InstanceId": "${aws:InstanceId}",
                    "InstanceType": "${aws:InstanceType}"
            },
            "metrics_collected": {
                    "cpu": {
                            "measurement": [
                                    "cpu_usage_idle",
                                    "cpu_usage_iowait",
                                    "cpu_usage_user",
                                    "cpu_usage_system"
                            ],
                            "metrics_collection_interval": 60,
                            "resources": [
                                    "*"
                            ],
                            "totalcpu": false
                    },
                   "mem": {
                            "measurement": [
                                    "mem_used_percent"
                            ],
                            "metrics_collection_interval": 60
                    },
                    "statsd": {
                            "service_address": ":8125",
                            "metrics_collection_interval": 15,
                            "metrics_aggregation_interval": 300
                    }
            }
    }
}